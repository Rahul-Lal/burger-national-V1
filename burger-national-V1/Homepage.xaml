<Page x:Class="burger_national_V1.Homepage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:burger_national_V1"
      mc:Ignorable="d" MaxHeight="1080" Height="1080" MaxWidth="1920"
      Title="Burger National" Background="#151515">

    <Grid Name="grdLayout" MaxWidth="1920" Width="1920">
        <Grid.Background>
            <ImageBrush ImageSource="/Assets/Images/burger-national-logo.png" Stretch="Uniform" Opacity="0.5"/>
        </Grid.Background>
        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Hidden" Margin="0,0,1475,0">
            <StackPanel Orientation="Horizontal" Height="1317">
                <TextBlock x:Name="txtOutput" TextWrapping="Wrap" FontSize="17.5" Width="346" MaxHeight="1080" Background="#FFFAF0" Foreground="#8B0000" Margin="0,0,0,236" TextAlignment="Left" Height="1078" VerticalAlignment="Top" />
                <TextBlock x:Name="txtPrices" TextWrapping="Wrap" FontSize="17.5" Width="79" MaxHeight="1080" Background="#FFFAF0" Foreground="#8B0000" TextAlignment="Right" Height="1078" VerticalAlignment="Top" />
            </StackPanel>
        </ScrollViewer>

        <TabControl Margin="423,0,0,167" HorizontalAlignment="Left" Width="1534" FontWeight="Bold" BorderThickness="3,1,3,1">
            <TabControl.Background>
                <ImageBrush Stretch="Fill"/>
            </TabControl.Background>
            <TabItem x:Name="btnEuropeanBurger" Header="European Burger" Width="250" Height="100" FontSize="22" HorizontalAlignment="Left" FontFamily="Bahnschrift" FontWeight="Bold" BorderThickness="3,0,3,0" Foreground="DarkRed">
                <TabItem.Background>
                    <LinearGradientBrush EndPoint="0,1">
                        <GradientStop Color="#FFF0F0F0"/>
                        <GradientStop Color="FloralWhite" Offset="1"/>
                    </LinearGradientBrush>
                </TabItem.Background>
                <Grid HorizontalAlignment="Left" Width="1498" Height="818" VerticalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300*"/>
                        <ColumnDefinition Width="300*"/>
                        <ColumnDefinition Width="300*"/>
                        <ColumnDefinition Width="300*"/>
                        <ColumnDefinition Width="300*"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="btnSingleOlympian" Content="Single Olympian" Width="280" Height="320" FontSize="30" HorizontalAlignment="Center" Click="btnSingleOlympian_Click" VerticalAlignment="Center" FontFamily="Bahnschrift">
                        <Button.Background>
                            <ImageBrush ImageSource="/Assets/Images/European-Burgers/Olympian Burger.png" Opacity="0.75"/>
                        </Button.Background>
                    </Button>
                    <Button x:Name="btnDoubleOlympian" Content="Double Olympian" Width="280" Height="320" FontSize="30" VerticalAlignment="Center" Click="btnDoubleOlympian_Click" RenderTransformOrigin="-0.356,0.981" Grid.Column="1" HorizontalAlignment="Center" FontFamily="Bahnschrift">
                        <Button.Background>
                            <ImageBrush ImageSource="/Assets/Images/European-Burgers/Double Olympian.png" Opacity="0.75"/>
                        </Button.Background>
                    </Button>
                    <Button x:Name="btnSingleParisian" Content="Single Parisian" Width="280" Height="320" FontSize="30" HorizontalAlignment="Center" VerticalAlignment="Center" Click="btnSingleParisian_Click" Grid.Column="2" FontFamily="Bahnschrift">
                        <Button.Foreground>
                            <ImageBrush/>
                        </Button.Foreground>
                        <Button.Background>
                            <ImageBrush ImageSource="/Assets/Images/European-Burgers/Parisan Burger.png" Opacity="0.75"/>
                        </Button.Background>
                    </Button>
                    <Button x:Name="btnDoubleParisian" Content="Double Parisian" Width="280" Height="320" FontSize="30" HorizontalAlignment="Center" VerticalAlignment="Center" Click="btnDoubleParisian_Click" RenderTransformOrigin="0.5,0.5" Grid.Column="3" FontFamily="Bahnschrift"/>
                    <Button x:Name="btnSingleRoma" Content="Single Roma" Width="280" Height="320" FontSize="30" HorizontalAlignment="Center" VerticalAlignment="Center" Click="btnSingleRoma_Click" Grid.Column="4" FontFamily="Bahnschrift"/>
                    <Button x:Name="btnDoubleRoma" Content="Double Roma" Height="320" FontSize="30" VerticalAlignment="Center" Click="btnDoubleRoma_Click" Width="280" Grid.Row="1" RenderTransformOrigin="0.167,0.55" HorizontalAlignment="Center" FontFamily="Bahnschrift"/>
                    <Button x:Name="btnSingleMatador" Content="Single Matador" Width="280" Height="320" FontSize="30" VerticalAlignment="Center" Click="btnSingleMatador_Click" Grid.Column="1" Grid.Row="1" HorizontalAlignment="Center" FontFamily="Bahnschrift"/>
                    <Button x:Name="btnDoubleMatador" Content="Double Matador" Width="280" Height="320" FontSize="30" VerticalAlignment="Center" Click="btnDoubleMatador_Click" Grid.Column="2" Grid.Row="1" HorizontalAlignment="Center" FontFamily="Bahnschrift"/>
                    <Button x:Name="btnSingleKaiser" Content="Single Kaiser" Width="280" Height="320" FontSize="30" VerticalAlignment="Center" Click="btnSingleKaiser_Click" RenderTransformOrigin="0.582,0.52" Grid.Row="1" Grid.Column="3" HorizontalAlignment="Center" FontFamily="Bahnschrift"/>
                    <Button x:Name="btnDoubleKaiser" Content="Double Kaiser" Width="280" Height="320" FontSize="30" VerticalAlignment="Center" Click="btnDoubleKaiser_Click" Grid.Column="4" Grid.Row="1" HorizontalAlignment="Center" FontFamily="Bahnschrift"/>
                </Grid>
            </TabItem>
            <TabItem x:Name="btnChickenOther" Header="Chicken + Other" Width="250" Height="100" FontSize="22" FontFamily="Bahnschrift" FontWeight="Bold" BorderThickness="3,0,3,0" Foreground="DarkRed">
                <TabItem.Background>
                    <LinearGradientBrush EndPoint="0,1">
                        <GradientStop Color="#FFF0F0F0"/>
                        <GradientStop Color="FloralWhite" Offset="1"/>
                    </LinearGradientBrush>
                </TabItem.Background>
            </TabItem>
            <TabItem x:Name="btnSides" Header="Sides" Width="250" Height="100" FontSize="22" FontFamily="Bahnschrift" FontWeight="Bold" BorderThickness="3,0,3,0" Foreground="DarkRed">
                <TabItem.Background>
                    <LinearGradientBrush EndPoint="0,1">
                        <GradientStop Color="#FFF0F0F0"/>
                        <GradientStop Color="FloralWhite" Offset="1"/>
                    </LinearGradientBrush>
                </TabItem.Background>
            </TabItem>
            <TabItem x:Name="btnDesserts" Header="Desserts" Width="250" Height="100" FontSize="22" FontFamily="Bahnschrift" FontWeight="Bold" BorderThickness="3,0,3,0" Foreground="DarkRed">
                <TabItem.Background>
                    <LinearGradientBrush EndPoint="0,1">
                        <GradientStop Color="#FFF0F0F0"/>
                        <GradientStop Color="FloralWhite" Offset="1"/>
                    </LinearGradientBrush>
                </TabItem.Background>
            </TabItem>
            <TabItem x:Name="btnDrinks" Header="Drinks" Width="250" Height="100" FontSize="22" FontFamily="Bahnschrift" FontWeight="Bold" BorderThickness="3,0,3,0" Foreground="DarkRed">
                <TabItem.Background>
                    <LinearGradientBrush EndPoint="0,1">
                        <GradientStop Color="#FFF0F0F0"/>
                        <GradientStop Color="FloralWhite" Offset="1"/>
                    </LinearGradientBrush>
                </TabItem.Background>
            </TabItem>
            <TabItem x:Name="btnCombo" Header="Combos + Add-Ons" Width="250" Height="100" FontSize="17.5" FontFamily="Bahnschrift" FontWeight="Bold" BorderThickness="3,0,3,0" Foreground="DarkRed" Background="FloralWhite"/>
        </TabControl>


        <Label Content="Sub Total: " HorizontalAlignment="Left" Margin="0,802,0,0" VerticalAlignment="Top" Height="39" Width="227" FontSize="22" FontWeight="Bold" Background="FloralWhite" VerticalContentAlignment="Center" Foreground="DarkRed" FontFamily="Bahnschrift"/>
        <TextBox x:Name="txtSubTotal" IsReadOnly="True" HorizontalAlignment="Left" Margin="227,805,0,0" TextWrapping="Wrap" Text="0.00" VerticalAlignment="Top" Width="196" Height="39" FontSize="22" TextAlignment="Center" Background="FloralWhite" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Foreground="DarkRed" FontFamily="Bahnschrift">
            <TextBox.BorderBrush>
                <SolidColorBrush Color="#FFABADB3" Opacity="0"/>
            </TextBox.BorderBrush>
        </TextBox>
        <Label Content="GST: " HorizontalAlignment="Left" Margin="0,842,0,0" VerticalAlignment="Top" Height="39" Width="227" FontSize="22" FontWeight="Bold" Background="FloralWhite" VerticalContentAlignment="Center" Foreground="DarkRed" FontFamily="Bahnschrift"/>
        <TextBox x:Name="txtGST" IsReadOnly="True" HorizontalAlignment="Left" Margin="227,843,0,0" TextWrapping="Wrap" Text="0.00" VerticalAlignment="Top" Width="196" Height="39" FontSize="22" TextAlignment="Center" Background="FloralWhite" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Foreground="DarkRed" FontFamily="Bahnschrift">
            <TextBox.BorderBrush>
                <SolidColorBrush Color="#FFABADB3" Opacity="0"/>
            </TextBox.BorderBrush>
        </TextBox>
        <Label Content="Total: " HorizontalAlignment="Left" Margin="0,880,0,0" VerticalAlignment="Top" Height="39" Width="227" FontSize="22" FontWeight="Bold" Background="FloralWhite" VerticalContentAlignment="Center" Foreground="DarkRed" FontFamily="Bahnschrift"/>
        <TextBox x:Name="txtTotal" IsReadOnly="True" HorizontalAlignment="Left" Margin="227,881,0,0" TextWrapping="Wrap" Text="0.00" VerticalAlignment="Top" Width="196" Height="39" FontSize="22" TextAlignment="Center" Background="FloralWhite" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Foreground="DarkRed" FontFamily="Bahnschrift">
            <TextBox.BorderBrush>
                <SolidColorBrush Color="#FFABADB3" Opacity="0"/>
            </TextBox.BorderBrush>
        </TextBox>

        <Button x:Name="btnClearOrder" Content="Clear Order" HorizontalAlignment="Left" Margin="423,0,0,0" VerticalAlignment="Bottom" Height="168" Width="280" Click="btnClearOrder_Click" FontSize="24" RenderTransformOrigin="1.845,0.412"/>
        <Button x:Name="btnPayment" Click="btnPayment_Click" Content="PAY" HorizontalAlignment="Left" VerticalAlignment="Bottom" Height="162" Width="423" FontSize="48" Background="DarkRed" Foreground="FloralWhite" FontWeight="Bold" FontFamily="Bahnschrift SemiBold" />
    </Grid>
</Page>
